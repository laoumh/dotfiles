#!/usr/bin/env bash
#
# Enable user systemd timers and services from dotfiles.
# Whenever creating new services on dot-config/systemd/user, add them here.
# Deploys system prerequisites and enables timers.

set -euo pipefail

DOTFILES="$(cd "$(dirname "$0")/.." && pwd)"
SYSTEM="$DOTFILES/system"

msg() { echo -e "\033[0;36m:: $*\033[0m"; }

msg "Deploying apt periodic config..."
sudo install -C -b -m 644 "$SYSTEM/etc/apt/apt.conf.d/10periodic" /etc/apt/apt.conf.d/10periodic

msg "Enabling user timers..."
systemctl --user daemon-reload
systemctl --user enable --now updates-notify.timer

echo "Done."
