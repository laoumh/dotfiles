# Usa nvim para ler Man pages
function nman {
    # --cmd é executado antes de carregar as configurações e -c depois
    check_command nvim && \
    nvim --clean --cmd ":cd ~" -c ":Man $1 | only"
}
# Tenta autocompletar nman com opções man
man_completion=/usr/share/bash-completion/completions/man
if [ -f "$man_completion" ] ; then
    source "$man_completion"
    complete -F _man nman
fi


# Copia para clipboard ou buffer tmux
copy() {
    if check_command wl-copy ; then
        wl-copy
    elif [[ -n "$TMUX" ]]; then
        tmux load-buffer -w -
    elif check_command xclip ; then
        xclip -i -selection clipboard
    else
        echo "copy: não encontrado clipboard nem sessão tmux ativa" >&2
        return 1
    fi
}
