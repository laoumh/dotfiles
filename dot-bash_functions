# Usa nvim para ler Man pages
function nman {
    # --cmd é executado antes de carregar as configurações e -c depois
    check_command nvim && \
    nvim --clean --cmd ":cd ~" -c ":Man $1 | only"
}
# Tenta autocompletar nman com opções man
man_completion=/usr/share/bash-completion/completions/man
if [ -f "$man_completion" ] ; then
    source "$man_completion"
    complete -F _man nman
fi


# Copia para clipboard ou buffer tmux
copy() {
    if check_command wl-copy ; then
        wl-copy
    elif [[ -n "$TMUX" ]]; then
        tmux load-buffer -w -
    elif check_command xclip ; then
        xclip -i -selection clipboard
    else
        echo "copy: não encontrado clipboard nem sessão tmux ativa" >&2
        return 1
    fi
}

### Forticlient
function ccuec-vpn-connect {
    local vpn_profile=ccuec-gw
    local user=lmaraujo

    if ! command -v forticlient > /dev/null ; then
        echo "Instalar e configurar forticlient"
        return 1
    fi

    if ! systemctl --quiet is-active forticlient.service ; then
        echo "Inicializando serviço forticlient"
        systemctl start forticlient.service
        sleep 2
    fi

    if ! forticlient vpn list | grep -q "$vpn_profile" ; then
        echo "Configurar perfil $vpn_profile"
        return 2
    fi

    forticlient vpn connect "$vpn_profile" -u "$user"
}

function ccuec-vpn-disconnect {
    local vpn_profile=ccuec-gw
    forticlient vpn disconnect "$vpn_profile"
    systemctl stop forticlient.service
    echo "Desconectado de $vpn_profile"
}

function ccuec-vpn-status {
    forticlient vpn status
}


